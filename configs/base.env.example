# --- Storage ---
STORAGE_ROOT=storage
RUNTIME_DB_PATH=storage/runtime.db

# --- MT5 Connection ---
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_WATCH_SYMBOLS=EURUSD,GBPUSD,USDJPY
MT5_WATCH_TIMEFRAMES=M1,M5,H1,H4,D1
MT5_POLL_SECONDS=1
MT5_BARS_PER_PULL=200
MT5_MAGIC_NUMBER=20260315
ACCOUNT_MODE=demo

# --- Core Runtime Cadence ---
CORE_SYMBOL_SPECS_REFRESH_SECONDS=60
CORE_SYMBOL_CATALOG_REFRESH_SECONDS=300
CORE_ACCOUNT_REFRESH_SECONDS=2
CORE_INDICATOR_REFRESH_SECONDS=2
# How often to write the in-memory candle structure to SQLite (seconds).
CORE_MARKET_STATE_CHECKPOINT_SECONDS=30

# --- Control Plane HTTP ---
# The only external interface to runtime state. No disk files should be read by clients.
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8765

# --- Broker Sessions Service ---
BROKER_SESSIONS_ENABLED=true
BROKER_SESSIONS_HOST=127.0.0.1
BROKER_SESSIONS_PORT=5561
BROKER_SESSIONS_RECV_TIMEOUT_MS=15000

# --- Indicator Enrichment ---
INDICATOR_ENRICHMENT_ENABLED=true
INDICATOR_ENRICHMENT_STALE_AFTER_SECONDS=180
# If empty, the bridge uses the MT5 Common\Files default path.
# IndicatorBridge applies snapshots to RAM only. Writing to storage/indicator_snapshots/ is forbidden.
MT5_COMMON_FILES_ROOT=

# --- SMC Desk ---
# Set to true to enable the Smart Money Concepts scanner and analyst.
SMC_SCANNER_ENABLED=false
# Override the symbol list for the SMC scanner (defaults to MT5_WATCH_SYMBOLS).
# SMC_SCANNER_SYMBOLS=EURUSD,GBPUSD,USDJPY
SMC_SCANNER_POLL_SECONDS=300
SMC_ANALYST_COOLDOWN_SECONDS=300
SMC_PERIODIC_REVIEW_SECONDS=14400
SMC_ZONE_APPROACH_PCT=1.5
SMC_MIN_IMPULSE_CANDLES=3
SMC_MAX_ACTIVE_ZONES_PER_SYMBOL=10
SMC_SCANNER_D1_BARS=100
SMC_SCANNER_H4_BARS=200
SMC_MIN_QUALITY_SCORE=0.2

# --- SMC LLM Validator (requires LocalAI running locally) ---
# Set SMC_LLM_ENABLED=false to skip LLM and rely on heuristics only.
SMC_LLM_ENABLED=false
SMC_LLM_MODEL=gemma-3-12b-it-qat
SMC_LLM_TIMEOUT_SECONDS=60
SMC_LLM_MAX_TOKENS=8192
SMC_LLM_TEMPERATURE=0.1
LOCALAI_BASE_URL=http://127.0.0.1:8080

# --- Fast Desk ---
# Set to true to enable the deterministic EMA/volume/ATR trading desk.
FAST_DESK_ENABLED=false
FAST_DESK_SCAN_INTERVAL=5.0
FAST_DESK_CUSTODY_INTERVAL=2.0
FAST_DESK_SIGNAL_COOLDOWN=60.0
FAST_DESK_RISK_PERCENT=1.0
FAST_DESK_MAX_POSITIONS_PER_SYMBOL=1
FAST_DESK_MAX_POSITIONS_TOTAL=4
FAST_DESK_MIN_CONFIDENCE=0.65
FAST_DESK_ATR_MULTIPLIER_SL=1.5
FAST_DESK_RR_RATIO=2.0

# --- Fast Trader (canonical env surface, backward compatible with FAST_DESK_*) ---
FAST_TRADER_ENABLED=false
FAST_TRADER_SCAN_INTERVAL=5.0
FAST_TRADER_GUARD_INTERVAL=2.0
FAST_TRADER_SIGNAL_COOLDOWN=60.0
FAST_TRADER_RISK_PERCENT=1.0
FAST_TRADER_MAX_POSITIONS_PER_SYMBOL=1
FAST_TRADER_MAX_POSITIONS_TOTAL=4
FAST_TRADER_MIN_CONFIDENCE=0.60
FAST_TRADER_ATR_MULTIPLIER_SL=1.5
FAST_TRADER_RR_RATIO=2.0
FAST_TRADER_SPREAD_TOLERANCE=medium
FAST_TRADER_ALLOWED_SESSIONS=london,overlap,new_york
FAST_TRADER_MAX_SLIPPAGE_POINTS=30
# Percentage-based slippage gate for context (v0.3.1+). Replaces hardcoded point threshold.
# If abs(tick - last_close) / tick_price > this %, blocks trading. Universal across all symbols.
FAST_TRADER_MAX_SLIPPAGE_PCT=0.05
FAST_TRADER_REQUIRE_H1_ALIGNMENT=true
FAST_TRADER_ENABLE_PENDING_ORDERS=true
FAST_TRADER_ENABLE_STRUCTURAL_TRAILING=true
FAST_TRADER_ENABLE_ATR_TRAILING=true
FAST_TRADER_ENABLE_SCALE_OUT=false
FAST_TRADER_PENDING_TTL_SECONDS=900
FAST_TRADER_ADOPTION_GRACE_SECONDS=120
FAST_TRADER_ADOPTION_GRACE_SECONDS=120

# --- Ownership + Risk Kernel ---
RISK_PROFILE_GLOBAL=2
RISK_PROFILE_FAST=2
RISK_PROFILE_SMC=2
RISK_MAX_DRAWDOWN_PCT=
RISK_MAX_RISK_PER_TRADE_PCT=
RISK_MAX_POSITIONS_TOTAL=
RISK_MAX_POSITIONS_PER_SYMBOL=
RISK_MAX_PENDING_ORDERS_TOTAL=
RISK_MAX_GROSS_EXPOSURE=
RISK_KILL_SWITCH_ENABLED=true
RISK_ADOPT_FOREIGN_POSITIONS=true
OWNERSHIP_HISTORY_RETENTION_DAYS=30
RISK_FAST_BUDGET_WEIGHT=1.2
RISK_SMC_BUDGET_WEIGHT=0.8
